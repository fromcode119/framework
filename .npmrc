# Route @fromcode119/* to GitHub Packages.
# In CI the NODE_AUTH_TOKEN env var is set automatically by actions/setup-node.
# For local development, create a GitHub PAT with read:packages + write:packages
# and export it: export GITHUB_TOKEN=<YOUR_GITHUB_TOKEN>
@fromcode119:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=${GITHUB_TOKEN}
