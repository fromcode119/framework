{
  "compilerOptions": {
    "target": "ESNext",
    "module": "CommonJS",
    "moduleResolution": "node",
    "declaration": true,
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@fromcode/core": ["packages/core/src"],
      "@fromcode/database": ["packages/database/src"],
      "@fromcode/sdk": ["packages/sdk/src"],
      "@fromcode/sdk/internal": ["packages/sdk/src/internal"],
      "@fromcode/auth": ["packages/auth/src"],
      "@fromcode/media": ["packages/media/src"],
      "@fromcode/email": ["packages/email/src"],
      "@fromcode/cache": ["packages/cache/src"],
      "@fromcode/scheduler": ["packages/scheduler/src"],
      "@fromcode/plugins": ["packages/plugins/src"],
      "@fromcode/marketplace-client": ["packages/marketplace-client/src"]
    },
    "composite": true,
    "jsx": "react-jsx",
    "noImplicitAny": false
  },
  "files": [],
  "references": [
    { "path": "./packages/core" },
    { "path": "./packages/sdk" },
    { "path": "./packages/react" },
    { "path": "./packages/next" },
    { "path": "./packages/cli" },
    { "path": "./packages/api" },
    { "path": "./packages/database" },
    { "path": "./packages/auth" },
    { "path": "./packages/media" },
    { "path": "./packages/email" },
    { "path": "./packages/cache" },
    { "path": "./packages/scheduler" },
    { "path": "./packages/plugins" },
    { "path": "./packages/marketplace-client" }
  ],
  "exclude": ["node_modules", "dist", "packages/admin", "packages/frontend"]
}
