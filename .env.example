# =============================================================================
# Fromcode — Environment Configuration
# Copy this file to .env and edit as needed.  No other env files are required.
# =============================================================================

# ---------------------------------------------------------------------------
# Database
# Default: SQLite (zero setup — works out of the box for local development)
# Switch to PostgreSQL by setting DB_DIALECT=postgres and updating DATABASE_URL
# ---------------------------------------------------------------------------
DB_DIALECT=sqlite
DATABASE_URL=file:./data/app.db

# PostgreSQL alternative (uncomment and set DB_DIALECT=postgres to use):
# DB_DIALECT=postgres
# DATABASE_URL=postgresql://CHANGE_ME_DB_USER:CHANGE_ME_DB_PASSWORD@localhost:5432/fromcode
# POSTGRES_USER=CHANGE_ME_DB_USER
# POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD
# POSTGRES_DB=fromcode

# ---------------------------------------------------------------------------
# Ports
# Bind ports for the three local processes.
# These are not duplicates: API, Admin, and Frontend each run their own server.
# ---------------------------------------------------------------------------
PORT=3000
ADMIN_PORT=3001
FRONTEND_PORT=3002

# Public browser URLs for each surface.
# Use these when the surfaces are on different origins (e.g. admin.example.com,
# www.example.com). In local single-origin proxy setups they may all collapse to
# one host, but the runtime still treats them as separate surfaces.
ADMIN_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3002
ALLOWED_DEV_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

# ---------------------------------------------------------------------------
# System
# ---------------------------------------------------------------------------
NODE_ENV=development
API_VERSION_PREFIX=v1
DEFAULT_LOCALE=en

# Browser-facing API origin.
# Next.js client bundles can only read NEXT_PUBLIC_* variables.
# In local dev this often matches API_URL; in Docker/production it is usually
# the public API host while API_URL may be an internal service address.
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_ADMIN_AI_ENABLED=false

# Server-to-server API origin (SSR, internal fetches, container-to-container calls).
# In Docker: use the service name, e.g. http://api:3000
# In local dev: use the public proxy or direct API host, e.g. http://localhost:3000
API_URL=http://localhost:3000

CORS_ALLOWED_DOMAINS=localhost
COOKIE_DOMAIN=.framework.local

# ---------------------------------------------------------------------------
# Redis
# Leave blank to use in-memory cache (fine for local dev, not for production)
# ---------------------------------------------------------------------------
REDIS_URL=

# ---------------------------------------------------------------------------
# Storage
# ---------------------------------------------------------------------------
STORAGE_DRIVER=local
STORAGE_UPLOAD_DIR=./public/uploads
STORAGE_PUBLIC_URL=http://localhost:3000/uploads

# ---------------------------------------------------------------------------
# Email
# Leave EMAIL_PROVIDER=mock to log emails to console instead of sending them
# ---------------------------------------------------------------------------
EMAIL_PROVIDER=mock
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ---------------------------------------------------------------------------
# Plugins & Themes
# These paths are relative to FROMCODE_PROJECT_ROOT (defaults to cwd)
# ---------------------------------------------------------------------------
PLUGINS_DIR=./plugins
THEMES_DIR=./themes
MARKETPLACE_URL=http://marketplace.framework.local

# Reverse proxy network used by Docker Compose / Traefik setups
EXTERNAL_PROXY_NETWORK=proxy

# Use one routing mode at a time:
# 1. Subdomain mode: admin.example.com, api.example.com, www.example.com
#    Leave NEXT_PUBLIC_ADMIN_BASE_PATH empty/unset.
# 2. Same-domain mode behind a gateway/proxy: example.com/admin
#    Set NEXT_PUBLIC_ADMIN_BASE_PATH=/admin in that deployment only.

# ---------------------------------------------------------------------------
# Security / Rate Limiting
# ---------------------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Security
# Replace before exposing the app outside local development.
JWT_SECRET=CHANGE_ME_JWT_SECRET_MIN_32_CHARS
