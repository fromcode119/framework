# Database Configuration
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=fromcode
DATABASE_URL=postgresql://user:password@db:5432/fromcode

# System Configuration
NODE_ENV=development
PUBLIC_URL=http://api.framework.local
NEXT_PUBLIC_API_URL=http://api.framework.local
CORS_ALLOWED_DOMAINS=framework.local,api.framework.local,admin.framework.local

# Redis Configuration
REDIS_URL=redis://redis:6379

# Storage Configuration
STORAGE_UPLOAD_DIR=/app/public/uploads
STORAGE_PUBLIC_URL=http://api.framework.local/uploads

# Plugin Configuration
PLUGINS_DIR=/app/plugins
MARKETPLACE_REGISTRY_URL=http://registry.framework.local/registry.json

# Internal Service URLs
INTERNAL_API_URL=http://api:3000
