# =============================================================================
# Fromcode — Environment Configuration
# Copy this file to .env and edit as needed.  No other env files are required.
# =============================================================================

# ---------------------------------------------------------------------------
# Database
# Default: SQLite (zero setup — works out of the box for local development)
# Switch to PostgreSQL by setting DB_DIALECT=postgres and updating DATABASE_URL
# ---------------------------------------------------------------------------
DB_DIALECT=sqlite
DATABASE_URL=file:./data/app.db

# PostgreSQL alternative (uncomment and set DB_DIALECT=postgres to use):
# DB_DIALECT=postgres
# DATABASE_URL=postgresql://user:password@localhost:5432/fromcode
# POSTGRES_USER=user
# POSTGRES_PASSWORD=password
# POSTGRES_DB=fromcode

# ---------------------------------------------------------------------------
# Ports
# ---------------------------------------------------------------------------
PORT=3000
ADMIN_PORT=3001
FRONTEND_PORT=3002

# ---------------------------------------------------------------------------
# System
# ---------------------------------------------------------------------------
NODE_ENV=development
API_VERSION_PREFIX=v1
DEFAULT_LOCALE=en
PUBLIC_URL=http://localhost:3000
# Internal server-to-server API URL (used by frontend SSR to reach the API inside Docker)
# In Docker: use the service name, e.g. http://api:3000
# In local dev: use http://localhost:3000
API_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000
CORS_ALLOWED_DOMAINS=localhost

# ---------------------------------------------------------------------------
# Redis
# Leave blank to use in-memory cache (fine for local dev, not for production)
# ---------------------------------------------------------------------------
REDIS_URL=

# ---------------------------------------------------------------------------
# Storage
# ---------------------------------------------------------------------------
STORAGE_DRIVER=local
STORAGE_UPLOAD_DIR=./public/uploads
STORAGE_PUBLIC_URL=http://localhost:3000/uploads

# ---------------------------------------------------------------------------
# Email
# Leave EMAIL_PROVIDER=mock to log emails to console instead of sending them
# ---------------------------------------------------------------------------
EMAIL_PROVIDER=mock
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ---------------------------------------------------------------------------
# Plugins & Themes
# These paths are relative to FROMCODE_PROJECT_ROOT (defaults to cwd)
# ---------------------------------------------------------------------------
PLUGINS_DIR=./plugins
THEMES_DIR=./themes
MARKETPLACE_URL=https://marketplace.fromcode.com/marketplace.json

# ---------------------------------------------------------------------------
# Security / Rate Limiting
# ---------------------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
