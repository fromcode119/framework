# Database Configuration
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=fromcode
DATABASE_URL=postgresql://user:password@db:5432/fromcode

# System Configuration
NODE_ENV=development
API_VERSION_PREFIX=v1
DEFAULT_LOCALE=en
PUBLIC_URL=http://api.fromcode.local
NEXT_PUBLIC_API_URL=http://api.fromcode.local
CORS_ALLOWED_DOMAINS=fromcode.local,api.fromcode.local,admin.fromcode.local

# Redis Configuration
REDIS_URL=redis://redis:6379

# Storage Configuration
STORAGE_DRIVER=local
STORAGE_UPLOAD_DIR=/app/public/uploads
STORAGE_PUBLIC_URL=http://api.fromcode.local/uploads

# Plugin & Marketplace Configuration
PLUGINS_DIR=/app/plugins
MARKETPLACE_URL=http://marketplace.fromcode.local/marketplace.json

# Internal Service URLs
INTERNAL_API_URL=http://api:3000

# Security / Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100