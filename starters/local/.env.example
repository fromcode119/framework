# ─────────────────────────────────────────────────────────────────────────────
# Fromcode app config  —  copy this file to .env and edit JWT_SECRET
#
#   cp .env.example .env
#
# This is the ONE config file for your app. No second .env.local needed.
# ─────────────────────────────────────────────────────────────────────────────

# Database — SQLite (zero setup). Switch to postgresql:// for production.
DB_DIALECT=sqlite
DATABASE_URL=file:./data/app.db

# Security — set a real random string (min 32 chars) before going live
JWT_SECRET=change-me-to-any-random-string-at-least-32-chars

# Cache — no REDIS_URL = in-memory cache (fine for single-server setups)
REDIS_URL=

# URLs
PUBLIC_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_ADMIN_BASE_PATH=/admin
API_URL=http://localhost:4000

# Ports (used by proxy.js and the concurrently scripts)
PROXY_PORT=3000
API_PORT=4000
ADMIN_PORT=3001
# FRONTEND_PORT=3002   # uncomment if you're also running a frontend

NODE_ENV=development
