# Route @fromcode119/* packages to GitHub Packages registry.
# You need a GitHub token with read:packages scope:
#   1. Go to https://github.com/settings/tokens → New token (classic)
#   2. Tick read:packages
#   3. export GITHUB_TOKEN=ghp_... (add to your shell profile)
@fromcode119:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=${GITHUB_TOKEN}
