# Fromcode app config — copy to .env, then edit JWT_SECRET
#
#   cp .env.example .env
#
# This is the only env file you need.

# Database — SQLite (zero setup). Switch to postgresql:// for production.
DB_DIALECT=sqlite
DATABASE_URL=file:./data/app.db

# Security — set a real random string (min 32 chars) before going live
JWT_SECRET=change-me-to-any-random-string-at-least-32-chars

# Cache — blank = in-memory (fine for single-server). Set for Redis.
REDIS_URL=

# URLs
PUBLIC_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_ADMIN_BASE_PATH=/admin
API_URL=http://localhost:4000
INTERNAL_API_URL=http://localhost:4000

# Ports (used by proxy.js and the npm scripts)
PROXY_PORT=3000
API_PORT=4000
ADMIN_PORT=3001
# FRONTEND_PORT=3002   # uncomment if running the frontend

NODE_ENV=development
